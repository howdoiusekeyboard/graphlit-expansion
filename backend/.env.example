# GraphLit Data Expansion System Configuration
# Copy this file to .env and fill in your values

# ============================================
# OpenAlex API Configuration
# ============================================
# API key (free, required since Feb 2026 — get yours at openalex.org/settings/api)
OPENALEX__API_KEY=your_api_key_here
# User agent for HTTP client identification
OPENALEX__USER_AGENT=GraphLit/1.0
# Rate limit: up to 100 req/sec with API key (singleton lookups are free)
OPENALEX__RATE_LIMIT_PER_SECOND=80
# Request timeout in seconds
OPENALEX__TIMEOUT_SECONDS=15
# Maximum retry attempts for failed requests
OPENALEX__MAX_RETRIES=3

# ============================================
# Neo4j Database Configuration
# ============================================
# Neo4j connection URI (bolt protocol)
NEO4J__URI=bolt://localhost:7687
# Neo4j username
NEO4J__USERNAME=neo4j
# Neo4j password (change this!)
NEO4J__PASSWORD=your_password_here
# Database name (neo4j is default, or create a new one)
NEO4J__DATABASE=neo4j

# ============================================
# Expansion Settings
# ============================================
# Maximum number of papers to collect
EXPANSION__MAX_PAPERS=1000
# Maximum BFS depth (0=seeds only, 1=seeds+neighbors, 2=two hops)
EXPANSION__MAX_DEPTH=2
# Minimum publication year filter
EXPANSION__YEAR_MIN=2015
# Maximum publication year filter
EXPANSION__YEAR_MAX=2025
# Optional: Computer Science concept IDs for filtering (comma-separated OpenAlex IDs)
# Leave empty to include all fields
# Example CS concepts: C41008148 (Computer Science), C154945302 (AI), C119857082 (ML)
EXPANSION__CS_CONCEPT_IDS=[]
# Maximum concurrent API fetches per BFS wave
EXPANSION__CONCURRENT_FETCHES=50
# Maximum items per Neo4j batch write
EXPANSION__NEO4J_BATCH_SIZE=500

# ============================================
# Analytics Configuration (Week 1 - ResearchRadar)
# ============================================
# GDS graph projection name
ANALYTICS__GDS_GRAPH_NAME=citation_network
# Community detection: maximum Louvain iterations
ANALYTICS__LOUVAIN_MAX_ITERATIONS=10
# Community detection: convergence tolerance
ANALYTICS__LOUVAIN_TOLERANCE=0.0001
# Community detection: minimum community size
ANALYTICS__MIN_COMMUNITY_SIZE=3
# Predictive Impact Score weights (must sum to 1.0)
ANALYTICS__PAGERANK_WEIGHT=0.30
ANALYTICS__CITATION_VELOCITY_WEIGHT=0.25
ANALYTICS__AUTHOR_REPUTATION_WEIGHT=0.25
ANALYTICS__TOPIC_MOMENTUM_WEIGHT=0.20
# PageRank algorithm settings
ANALYTICS__PAGERANK_DAMPING_FACTOR=0.85
ANALYTICS__PAGERANK_MAX_ITERATIONS=20
